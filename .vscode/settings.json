{
  "clangd.arguments": [
    "--compile-commands-dir=${workspaceFolder}/build/ninja",
    "--query-driver=/usr/bin/arm-none-eabi-*"
  ],
  "C_Cpp.intelliSenseEngine": "disabled",
  "editor.detectIndentation": false,
  "editor.tabSize": 4,
  "editor.insertSpaces": true,
  "files.watcherExclude": {
    "**/build/**": true,
    "**/_build/**": true,
    "**/Debug/**": true
  }
}
