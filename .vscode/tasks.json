{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "CMake: configure",
      "type": "shell",
      "command": "cmake",
      "args": [
        "-S",
        ".",
        "-B",
        "build/ninja",
        "-G",
        "Ninja",
        "-DCMAKE_TOOLCHAIN_FILE=tools/build/arm-none-eabi-gcc.cmake"
      ],
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "problemMatcher": []
    },
    {
      "label": "CMake: build",
      "type": "shell",
      "command": "cmake",
      "args": [
        "--build",
        "build/ninja"
      ],
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "group": {
        "kind": "build",
        "isDefault": true
      },
      "dependsOn": [
        "CMake: configure"
      ],
      "problemMatcher": "$gcc"
    },
    {
      "label": "CMake: flash",
      "type": "shell",
      "command": "cmake",
      "args": [
        "--build",
        "build/ninja",
        "--target",
        "flash"
      ],
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "dependsOn": [
        "CMake: build"
      ],
      "problemMatcher": "$gcc"
    }
  ]
}
